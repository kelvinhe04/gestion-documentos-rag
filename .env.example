# ============================================================
#  Configuración del Sistema de Gestión de Documentos con RAG
#  Copia este archivo como ".env" y completa tus valores.
# ============================================================

# ---- Proveedor de LLM para el chatbot RAG ----
# Opciones: groq | ollama | none
#   groq   -> Modelos open source (Llama 3) en la nube. Gratis con API key.
#   ollama -> LLM local (requiere tener Ollama corriendo).
#   none   -> Sin LLM generativo; usa respuesta extractiva (siempre funciona).
LLM_PROVIDER=groq

# ---- Groq (https://console.groq.com/keys -> crear API key gratis) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ---- Ollama (solo si LLM_PROVIDER=ollama) ----
OLLAMA_MODEL=llama3.1
OLLAMA_HOST=http://localhost:11434

# ---- Parámetros del pipeline / RAG ----
COLLECTION_NAME=documentos_academicos
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
LLM_TEMPERATURE=0.2
